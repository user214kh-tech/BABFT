-- Dragging
local dragging, dragInput, dragStart, startPos
titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)
titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ==================== PAINT LOGIC ====================
paintBtn.MouseButton1Click:Connect(function()
    -- Get the Remote only when painting (so UI loads immediately)
    local tool = player.Character:FindFirstChild("PaintingTool") or player.Character:WaitForChild("PaintingTool", 3)
    if not tool then
        status.Text = "❌ PaintingTool not equipped"
        return
    end
    local Event = tool:FindFirstChild("RF")
    if not Event then
        status.Text = "❌ RF missing on tool"
        return
    end

    local fullText = textBox.Text
    local gridStart = fullText:find("GRID:")
    if not gridStart then
        status.Text = "❌ No GRID: found in text"
        return
    end

    local gridStr = fullText:sub(gridStart + 5):gsub("%s+", ""):sub(1, SIZE*SIZE)
    if #gridStr ~= SIZE*SIZE then
        status.Text = "❌ Wrong grid length!"
        return
    end

    -- Parse legend for colors
    local colorMap = {}
    local legendStart = fullText:find("LEGEND:")
    if legendStart then
        local legendText = fullText:sub(legendStart + 7, gridStart - 1)
        for line in legendText:gmatch("[^\r\n]+") do
            local sym, r, g, b = line:match("(%w)%s*=%s*.-Color3%.new%(([%d%.]+),%s*([%d%.]+),%s*([%d%.]+)%)")
            if sym and r and g and b then
                colorMap[sym] = Color3.new(tonumber(r), tonumber(g), tonumber(b))
            end
        end
    end

    status.Text = "Painting..."
    paintBtn.Text = "PAINTING..."
    paintBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 90)

    local BATCH_SIZE = 250
    local batch = {}

    for i = 1, #gridStr do
        local char = gridStr:sub(i, i)
        local color = colorMap[char] or Color3.new(0,0,0)
        local block = blocksFolder:GetChildren()[i]
        if block then table.insert(batch, {block, color}) end

        if #batch >= BATCH_SIZE or i == #gridStr then
            if #batch > 0 then Event:InvokeServer(batch) end
            batch = {}
            if i % 750 == 0 then task.wait(0.01) end
        end
    end

    status.Text = "✅ Done!"
    paintBtn.Text = "PAINT (Fast)"
end)


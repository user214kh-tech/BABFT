<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pixel Data Converter</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#111114;
    --panel:#191a1f;
    --line:#2a2b32;
    --ink:#eae7e0;
    --dim:#8b8c94;
    --accent:#3ddc97;
    --accent-dim:#2a9c6d;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:'JetBrains Mono', monospace;
    min-height:100vh;
    padding:16px 16px 60px;
  }
  .wrap{max-width:920px;margin:0 auto;}
  header{margin-bottom:22px;}
  h1{
    font-family:'Press Start 2P', monospace;
    font-size:14px;
    line-height:1.6;
    letter-spacing:0.5px;
    margin:0 0 10px;
    color:var(--ink);
  }
  h1 span{color:var(--accent);}
  header p{margin:0;color:var(--dim);font-size:12px;max-width:56ch;}

  .layout{
    display:grid;
    grid-template-columns: 1fr;
    gap:18px;
  }
  @media(min-width:760px){
    .layout{grid-template-columns: 300px 1fr;}
  }

  .panel{
    background:var(--panel);
    border:1px solid var(--line);
    border-radius:2px;
    padding:16px;
  }
  .panel + .panel{margin-top:16px;}

  .drop{
    border:1px dashed var(--line);
    border-radius:2px;
    padding:26px 14px;
    text-align:center;
    cursor:pointer;
    transition:border-color .15s ease, background .15s ease;
  }
  .drop:hover, .drop.drag{
    border-color:var(--accent);
    background:#151920;
  }
  .drop input{display:none;}
  .drop .icon{font-size:22px;color:var(--accent);margin-bottom:8px;}
  .drop .txt{font-size:12.5px;color:var(--dim);}
  .drop .txt b{color:var(--ink);}

  .field{margin-top:16px;}
  .field label{
    display:flex;justify-content:space-between;
    font-size:11px;color:var(--dim);margin-bottom:6px;
    text-transform:uppercase;letter-spacing:0.06em;
  }
  .field label span.val{color:var(--accent);}
  select{
    width:100%;background:#101115;color:var(--ink);
    border:1px solid var(--line);padding:7px 8px;
    font-family:inherit;font-size:12.5px;border-radius:2px;
  }

  button{
    font-family:inherit;
    font-size:12px;
    letter-spacing:0.03em;
    padding:10px 14px;
    border-radius:2px;
    border:1px solid var(--line);
    background:#101115;
    color:var(--ink);
    cursor:pointer;
    transition:border-color .15s ease, color .15s ease;
  }
  button:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
  button:disabled{opacity:0.35;cursor:not-allowed;}

  button.primary{
    background:var(--accent);
    border-color:var(--accent);
    color:#0b1410;
    font-weight:700;
    width: 100%;
    margin-bottom: 10px;
  }
  button.primary:hover:not(:disabled){color:#0b1410;border-color:var(--accent-dim);background:var(--accent-dim);}

  .stage{
    display:flex;flex-direction:column;align-items:center;
    gap:14px;
  }
  .canvases{
    display:flex;gap:22px;flex-wrap:wrap;justify-content:center;align-items:flex-start;
  }
  .canvasblock{text-align:center;}
  .canvasblock .cap{
    font-size:10.5px;color:var(--dim);text-transform:uppercase;
    letter-spacing:0.08em;margin-bottom:8px;
  }
  canvas{
    image-rendering:pixelated;
    border:1px solid var(--line);
    background:#000;
    max-width:100%;
  }
  #srcCanvas{width:120px;height:120px;}
  #outCanvas{width:220px;height:220px;max-width:60vw;max-height:60vw;}

  .empty{
    color:var(--dim);font-size:12.5px;text-align:center;
    padding:60px 20px;
  }

  .palette{
    display:flex;flex-direction:column;gap:5px;margin-top:8px;max-height:340px;overflow-y:auto;
  }
  .prow{
    display:flex;align-items:center;gap:8px;
    border:1px solid var(--line);border-radius:2px;padding:4px 7px;
  }
  .prow .sw{
    width:18px;height:18px;flex:none;border-radius:2px;border:1px solid rgba(255,255,255,0.15);
  }
  .prow .sym{
    font-weight:700;color:var(--accent);width:30px;flex:none;text-align:center;font-size:11px;
  }
  .prow .nm{font-size:10.5px;color:var(--ink);flex:1;}
  .prow .nm span{color:var(--dim);font-size:9px;display:block;}
  .prow .pct{font-size:9.5px;color:var(--dim);flex:none;}
  .palette-hint{
    font-size:10.5px;color:var(--dim);margin-top:10px;line-height:1.5;
  }

  .log{
    margin-top:14px;
    width: 100%;
  }
  .log textarea{
    width:100%;height:220px;resize:vertical;
    background:#101115;color:var(--accent);border:1px solid var(--line);
    border-radius:2px;padding:8px;font-family:'JetBrains Mono', monospace;font-size:10px;line-height:1.4;
    word-break: break-all;
  }
  .log .cap{font-size:11px;color:var(--dim);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;}
  .log .cap b{color:var(--ink);}

  footer{margin-top:24px;color:var(--dim);font-size:11px;text-align:center;}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1><span id="titleSize">75×75</span> <span>PIXEL DATA</span> CONVERTER</h1>
    <p>Upload any image. The tool clusters its actual colors, assigns each a symbol, and exports a clean LEGEND + GRID block formatted for easy parsing in Roblox Lua.</p>
  </header>

  <div class="layout">
    <div class="col-left">
      <div class="panel">
        <div class="drop" id="drop">
          <div class="icon">&#9635;</div>
          <div class="txt"><b>Click to upload</b><br>or drag an image here</div>
          <input type="file" id="fileInput" accept="image/*">
        </div>

        <div class="field">
          <label>Grid size <span class="val" id="gridLabel">75 × 75</span></label>
          <select id="gridSelect">
            <option value="25">25 × 25</option>
            <option value="50">50 × 50</option>
            <option value="75" selected>75 × 75</option>
            <option value="100">100 × 100</option>
            <option value="125">125 × 125</option>
            <option value="150">150 × 150</option>
            <option value="200">200 × 200</option>
          </select>
        </div>

        <div class="field">
          <label>Colors to detect <span class="val" id="colorsLabel">16</span></label>
          <select id="colorsSelect">
            <option value="4">4 colors</option>
            <option value="8">8 colors</option>
            <option value="12">12 colors</option>
            <option value="16" selected>16 colors</option>
            <option value="24">24 colors</option>
            <option value="32">32 colors</option>
            <option value="48">48 colors</option>
            <option value="64">64 colors</option>
            <option value="100">100 colors</option>
            <option value="150">150 colors</option>
            <option value="200">200 colors</option>
            <option value="300">300 colors</option>
          </select>
        </div>

        <div class="field">
          <label>Dithering <span class="val" id="ditherLabel">On</span></label>
          <select id="ditherSelect">
            <option value="on">Floyd–Steinberg (on)</option>
            <option value="off">Nearest color only (off)</option>
          </select>
        </div>
      </div>

      <div class="panel">
        <div class="cap" style="font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">Detected Palette</div>
        <div class="palette" id="palette"><div class="empty" style="padding:20px 6px;">Upload an image to detect its colors.</div></div>
        <div class="palette-hint">Colors are extracted from your specific image via clustering, ranked by how much of the image they cover. Symbols are reassigned fresh for every image — always read the LEGEND before decoding the GRID.</div>
      </div>
    </div>

    <div class="col-right">
      <div class="panel stage">
        <div id="emptyState" class="empty">No image yet — upload one to see it converted here.</div>
        <div class="canvases" id="canvasArea" style="display:none;">
          <div class="canvasblock">
            <div class="cap"><span id="srcCap">Source (75×75)</span></div>
            <canvas id="srcCanvas" width="75" height="75"></canvas>
          </div>
          <div class="canvasblock">
            <div class="cap">Processed Result</div>
            <canvas id="outCanvas" width="75" height="75"></canvas>
          </div>
        </div>

        <div class="log" id="logArea" style="display:none;width:100%;">
          <div class="cap"><b>LEGEND + GRID Output</b></div>
          <button class="primary" id="copyCodeBtn" disabled>Copy Output</button>
          <textarea id="logText" readonly></textarea>
        </div>
      </div>
    </div>
  </div>

  <footer>All processing happens locally in your browser.</footer>
</div>

<script>
// Symbols are fixed-width zero-padded numbers ("000", "001", ...) instead of
// single characters. This removes the 62-color ceiling (supports up to 1000
// colors) and is trivial to parse in Lua: just read fixed-width chunks.
const SYMBOL_WIDTH = 3;
function symbolFor(i){
  return String(i).padStart(SYMBOL_WIDTH, '0');
}

let GRID = 75;
let K = 16;
let lastResult = null;   // grid of {char, rgb255, idx}
let lastPalette = null;  // array of {rgb255, char, name, count}
let rawBuf = null;       // Float32Array of cropped/resized source pixels

const paletteEl = document.getElementById('palette');
const drop = document.getElementById('drop');
const fileInput = document.getElementById('fileInput');
const emptyState = document.getElementById('emptyState');
const canvasArea = document.getElementById('canvasArea');
const logArea = document.getElementById('logArea');
const srcCanvas = document.getElementById('srcCanvas');
const outCanvas = document.getElementById('outCanvas');
const logText = document.getElementById('logText');
const ditherSelect = document.getElementById('ditherSelect');
const ditherLabel = document.getElementById('ditherLabel');
const gridSelect = document.getElementById('gridSelect');
const gridLabel = document.getElementById('gridLabel');
const colorsSelect = document.getElementById('colorsSelect');
const colorsLabel = document.getElementById('colorsLabel');
const titleSize = document.getElementById('titleSize');
const srcCap = document.getElementById('srcCap');
const copyCodeBtn = document.getElementById('copyCodeBtn');

drop.addEventListener('click', () => fileInput.click());
drop.addEventListener('dragover', e => {e.preventDefault(); drop.classList.add('drag');});
drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
drop.addEventListener('drop', e => {
  e.preventDefault(); drop.classList.remove('drag');
  if(e.dataTransfer.files && e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => {
  if(fileInput.files && fileInput.files[0]) handleFile(fileInput.files[0]);
});
ditherSelect.addEventListener('change', () => {
  ditherLabel.textContent = ditherSelect.value === 'on' ? 'On' : 'Off';
  if(rawBuf) recomputeWithExistingPalette();
});
gridSelect.addEventListener('change', () => {
  const n = gridSelect.value;
  gridLabel.textContent = `${n} × ${n}`;
  titleSize.textContent = `${n}×${n}`;
  srcCap.textContent = `Source (${n}×${n})`;
  if(window.__lastImg) processImage(window.__lastImg);
});
colorsSelect.addEventListener('change', () => {
  colorsLabel.textContent = colorsSelect.value;
  if(window.__lastImg) processImage(window.__lastImg);
});

function handleFile(file){
  if(!file.type.startsWith('image/')) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      window.__lastImg = img;
      processImage(img);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function clamp(v){return v<0?0:v>255?255:v;}

function processImage(img){
  emptyState.style.display = 'none';
  canvasArea.style.display = 'flex';
  logArea.style.display = 'block';

  GRID = parseInt(gridSelect.value, 10);
  K = parseInt(colorsSelect.value, 10);
  srcCanvas.width = GRID; srcCanvas.height = GRID;
  outCanvas.width = GRID; outCanvas.height = GRID;

  const side = Math.min(img.width, img.height);
  const sx = (img.width - side)/2;
  const sy = (img.height - side)/2;

  const work = document.createElement('canvas');
  work.width = GRID; work.height = GRID;
  const wctx = work.getContext('2d');
  wctx.imageSmoothingEnabled = true;
  wctx.imageSmoothingQuality = 'high';
  wctx.drawImage(img, sx, sy, side, side, 0, 0, GRID, GRID);

  const sctx = srcCanvas.getContext('2d');
  sctx.clearRect(0,0,GRID,GRID);
  sctx.drawImage(work, 0, 0);

  const imgData = wctx.getImageData(0,0,GRID,GRID);
  const data = imgData.data;

  rawBuf = new Float32Array(GRID*GRID*3);
  for(let i=0;i<GRID*GRID;i++){
    rawBuf[i*3]   = data[i*4];
    rawBuf[i*3+1] = data[i*4+1];
    rawBuf[i*3+2] = data[i*4+2];
  }

  const centroids = kMeans(rawBuf, GRID*GRID, K, 12);
  lastPalette = buildPaletteFromCentroids(centroids);
  renderPaletteUI();

  recomputeWithExistingPalette();
  copyCodeBtn.disabled = false;
}

// ---- K-means clustering on the pixel colors (k-means++ init) ----
function kMeans(buf, n, k, iterations){
  k = Math.min(k, n);
  const centroids = [];
  const firstIdx = Math.floor(Math.random()*n);
  centroids.push([buf[firstIdx*3], buf[firstIdx*3+1], buf[firstIdx*3+2]]);

  const distSq = (i, c) => {
    const dr = buf[i*3]-c[0], dg = buf[i*3+1]-c[1], db = buf[i*3+2]-c[2];
    return dr*dr+dg*dg+db*db;
  };

  while(centroids.length < k){
    const dists = new Float64Array(n);
    let sum = 0;
    for(let i=0;i<n;i++){
      let best = Infinity;
      for(const c of centroids){
        const d = distSq(i, c);
        if(d < best) best = d;
      }
      dists[i] = best;
      sum += best;
    }
    if(sum === 0){
      const idx = Math.floor(Math.random()*n);
      centroids.push([buf[idx*3], buf[idx*3+1], buf[idx*3+2]]);
      continue;
    }
    let r = Math.random()*sum;
    let chosen = 0;
    for(let i=0;i<n;i++){
      r -= dists[i];
      if(r <= 0){ chosen = i; break; }
    }
    centroids.push([buf[chosen*3], buf[chosen*3+1], buf[chosen*3+2]]);
  }

  const labels = new Int32Array(n);
  for(let iter=0; iter<iterations; iter++){
    for(let i=0;i<n;i++){
      let best=-1, bestD=Infinity;
      for(let c=0;c<centroids.length;c++){
        const d = distSq(i, centroids[c]);
        if(d<bestD){bestD=d;best=c;}
      }
      labels[i] = best;
    }
    const sums = centroids.map(()=>[0,0,0,0]);
    for(let i=0;i<n;i++){
      const s = sums[labels[i]];
      s[0]+=buf[i*3]; s[1]+=buf[i*3+1]; s[2]+=buf[i*3+2]; s[3]++;
    }
    for(let c=0;c<centroids.length;c++){
      if(sums[c][3]>0){
        centroids[c] = [sums[c][0]/sums[c][3], sums[c][1]/sums[c][3], sums[c][2]/sums[c][3]];
      }
    }
  }
  return centroids;
}

function buildPaletteFromCentroids(centroids){
  const n = GRID*GRID;
  const counts = new Array(centroids.length).fill(0);
  for(let i=0;i<n;i++){
    const idx = nearestCentroid(rawBuf[i*3], rawBuf[i*3+1], rawBuf[i*3+2], centroids);
    counts[idx]++;
  }
  const entries = centroids.map((rgb, i) => ({rgb255: rgb.map(v => clamp(Math.round(v))), count: counts[i]}));
  entries.sort((a,b) => b.count - a.count);
  entries.forEach((e, i) => {
    e.char = symbolFor(i);
    e.name = nameColor(e.rgb255[0], e.rgb255[1], e.rgb255[2]);
  });
  return entries;
}

function nearestCentroid(r,g,b,centroids){
  let bestI=-1, bestD=Infinity;
  for(let i=0;i<centroids.length;i++){
    const c = centroids[i];
    const dr=r-c[0], dg=g-c[1], db=b-c[2];
    const d=dr*dr+dg*dg+db*db;
    if(d<bestD){bestD=d;bestI=i;}
  }
  return bestI;
}

// ---- Simple heuristic color naming from RGB via HSL ----
function nameColor(r,g,b){
  const rn=r/255, gn=g/255, bn=b/255;
  const max=Math.max(rn,gn,bn), min=Math.min(rn,gn,bn);
  const l=(max+min)/2;
  let h=0, s=0;
  const d=max-min;
  if(d!==0){
    s = d/(1-Math.abs(2*l-1));
    switch(max){
      case rn: h = 60*(((gn-bn)/d)%6); break;
      case gn: h = 60*(((bn-rn)/d)+2); break;
      case bn: h = 60*(((rn-gn)/d)+4); break;
    }
  }
  if(h<0) h+=360;

  if(l < 0.08) return "Black";
  if(l > 0.94 && s < 0.15) return "White";
  if(s < 0.10){
    if(l < 0.30) return "Dark Grey";
    if(l < 0.65) return "Grey";
    return "Light Grey";
  }

  let base;
  if(h < 15) base = "Red";
  else if(h < 40) base = "Orange";
  else if(h < 65) base = "Yellow";
  else if(h < 90) base = "Yellow-Green";
  else if(h < 150) base = "Green";
  else if(h < 185) base = "Teal";
  else if(h < 205) base = "Cyan";
  else if(h < 250) base = "Blue";
  else if(h < 280) base = "Indigo";
  else if(h < 320) base = "Purple";
  else if(h < 345) base = "Pink";
  else base = "Red";

  let prefix = "";
  if(l < 0.28) prefix = "Dark ";
  else if(l > 0.75) prefix = "Light ";
  else if(s < 0.35) prefix = "Muted ";

  return (prefix + base).trim();
}

function toColor3New(rgb255){
  const r = (rgb255[0]/255).toFixed(3);
  const g = (rgb255[1]/255).toFixed(3);
  const b = (rgb255[2]/255).toFixed(3);
  return `Color3.new(${r},${g},${b})`;
}

function renderPaletteUI(){
  paletteEl.innerHTML = "";
  lastPalette.forEach(entry => {
    const pct = ((entry.count / (GRID*GRID)) * 100).toFixed(1);
    const row = document.createElement('div');
    row.className = 'prow';
    row.innerHTML = `
      <div class="sym">${entry.char}</div>
      <div class="sw" style="background:rgb(${entry.rgb255[0]},${entry.rgb255[1]},${entry.rgb255[2]})"></div>
      <div class="nm">${entry.name}<span>${toColor3New(entry.rgb255)}</span></div>
      <div class="pct">${pct}%</div>
    `;
    paletteEl.appendChild(row);
  });
}

// Re-run quantization against the already-detected palette (used when
// toggling dithering, without re-clustering).
function recomputeWithExistingPalette(){
  if(!rawBuf || !lastPalette) return;
  const useDither = ditherSelect.value === 'on';
  const centroids = lastPalette.map(e => e.rgb255);
  const buf = Float32Array.from(rawBuf);
  const result = [];
  for(let y=0;y<GRID;y++) result.push(new Array(GRID));

  for(let y=0;y<GRID;y++){
    for(let x=0;x<GRID;x++){
      const i = y*GRID+x;
      const r = buf[i*3], g = buf[i*3+1], b = buf[i*3+2];
      const idx = nearestCentroid(r,g,b,centroids);
      const entry = lastPalette[idx];
      result[y][x] = {char: entry.char, rgb255: entry.rgb255, idx};

      if(useDither){
        const er = r - entry.rgb255[0];
        const eg = g - entry.rgb255[1];
        const eb = b - entry.rgb255[2];
        const spread = (xx,yy,f) => {
          if(xx>=0 && xx<GRID && yy>=0 && yy<GRID){
            const j=(yy*GRID+xx)*3;
            buf[j]   = clamp(buf[j]   + er*f);
            buf[j+1] = clamp(buf[j+1] + eg*f);
            buf[j+2] = clamp(buf[j+2] + eb*f);
          }
        };
        spread(x+1,y,   7/16);
        spread(x-1,y+1, 3/16);
        spread(x,  y+1, 5/16);
        spread(x+1,y+1, 1/16);
      }
    }
  }

  lastResult = result;

  const octx = outCanvas.getContext('2d');
  const outData = octx.createImageData(GRID, GRID);
  for(let y=0;y<GRID;y++){
    for(let x=0;x<GRID;x++){
      const {rgb255} = result[y][x];
      const i = (y*GRID+x)*4;
      outData.data[i]=rgb255[0]; outData.data[i+1]=rgb255[1]; outData.data[i+2]=rgb255[2]; outData.data[i+3]=255;
    }
  }
  octx.putImageData(outData, 0, 0);

  buildLog();
}

function buildLog(){
  const legendLines = lastPalette.map(e => `${e.char}=${e.name.replace(/\s+/g,'')} ${toColor3New(e.rgb255)}`);

  let gridStream = "";
  for(let y = GRID - 1; y >= 0; y--){
    for(let x = 0; x < GRID; x++){
      gridStream += lastResult[y][x].char;
    }
  }

  logText.value = `LEGEND:\n${legendLines.join("\n")}\n\nGRID:\n${gridStream}`;
}

copyCodeBtn.addEventListener('click', () => {
  logText.select();
  document.execCommand('copy');
  const oldText = copyCodeBtn.textContent;
  copyCodeBtn.textContent = 'Copied!';
  setTimeout(() => { copyCodeBtn.textContent = oldText; }, 1500);
});
</script>
</body>
</html>
